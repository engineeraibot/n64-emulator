script-source,81,/sessions/ecstatic-vigilant-tesla/mnt/n64-emulator/tmp_state.js,// Reusable save/restore of full machine state for fast post-title debugging.\x0d\nconst fs=require('fs');\x0d\nfunction saveState(file\x2C ram\x2C mmu\x2C cpu\x2C rcp){\x0d\n  const meta={\x0d\n    cpu:{\x0d\n      gpr:Array.from(cpu.gpr)\x2C gprHi:Array.from(cpu.gprHi)\x2C\x0d\n      cp0:Array.from(cpu.cp0Registers)\x2C\x0d\n      fpr:Buffer.from(new Uint8Array(cpu.fprBuffer)).toString('base64')\x2C\x0d\n      fcr0:cpu.fcr0\x2C fcr31:cpu.fcr31\x2C pc:cpu.pc|0\x2C\x0d\n      hi:cpu.hi|0\x2C lo:cpu.lo|0\x2C hiH:cpu.hiH|0\x2C loH:cpu.loH|0\x2C\x0d\n      compareArmed:cpu._compareArmed\x2C lastFiredCompare:cpu._lastFiredCompare\x2C\x0d\n      instructionCount:cpu.instructionCount\x2C\x0d\n      isHleBootDone:cpu.isHleBootDone\x2C isRunning:cpu.isRunning\x2C\x0d\n      branchTaken:cpu.branchTaken\x2C branchTarget:cpu.branchTarget|0\x2C\x0d\n      tlb:cpu.tlbEntries.map(e=>e?{pageMask:e.pageMask\x2CentryHi:e.entryHi\x2CentryLo0:e.entryLo0\x2CentryLo1:e.entryLo1}:null)\x2C\x0d\n    }\x2C\x0d\n    mmu:{\x0d\n      vi:Array.from(mmu.viRegisters)\x2C mi:Array.from(mmu.miRegisters)\x2C\x0d\n      pi:Array.from(mmu.piRegisters)\x2C si:Array.from(mmu.siRegisters)\x2C\x0d\n      sp:Array.from(mmu.spRegisters)\x2C dpc:Array.from(mmu.dpcRegisters)\x2C\x0d\n      ai:Array.from(mmu.aiRegisters)\x2C ri:Array.from(mmu.riRegisters)\x2C\x0d\n      pifRam:Buffer.from(mmu.pifRam).toString('base64')\x2C\x0d\n      eeprom:Buffer.from(mmu.eeprom).toString('base64')\x2C\x0d\n      spDmem:Buffer.from(mmu.spDmem).toString('base64')\x2C\x0d\n      spImem:Buffer.from(mmu.spImem).toString('base64')\x2C\x0d\n      piBusyUntil:mmu.piBusyUntil\x2C siBusyUntil:mmu.siBusyUntil\x2C\x0d\n      aiBusyUntil:mmu.aiBusyUntil\x2C aiQueuedDuration:mmu.aiQueuedDuration\x2C\x0d\n      viNextInterrupt:mmu.viNextInterrupt\x2C siDmaDirection:mmu.siDmaDirection\x2C\x0d\n      siDramAddr:mmu.siDramAddr\x2C buttons:mmu.buttons\x2C stickX:mmu.stickX\x2C stickY:mmu.stickY\x2C\x0d\n    }\x2C\x0d\n    rcp:{ f3dTaskCount:rcp.f3dTaskCount|0\x2C rspTaskCount:rcp.rspTaskCount|0 }\x2C\x0d\n  };\x0d\n  fs.writeFileSync(file+'.rdram'\x2C Buffer.from(new Uint8Array(ram.rdram)));\x0d\n  fs.writeFileSync(file+'.json'\x2C JSON.stringify(meta));\x0d\n}\x0d\nfunction loadState(file\x2C ram\x2C mmu\x2C cpu\x2C rcp){\x0d\n  const rd=fs.readFileSync(file+'.rdram');\x0d\n  new Uint8Array(ram.rdram).set(new Uint8Array(rd.buffer\x2Crd.byteOffset\x2Crd.byteLength));\x0d\n  const m=JSON.parse(fs.readFileSync(file+'.json'\x2C'utf8'));\x0d\n  const c=m.cpu;\x0d\n  cpu.gpr.set(c.gpr); cpu.gprHi.set(c.gprHi); cpu.cp0Registers.set(c.cp0);\x0d\n  new Uint8Array(cpu.fprBuffer).set(Buffer.from(c.fpr\x2C'base64'));\x0d\n  cpu.fcr0=c.fcr0; cpu.fcr31=c.fcr31; cpu.pc=c.pc|0;\x0d\n  cpu.hi=c.hi|0; cpu.lo=c.lo|0; cpu.hiH=c.hiH|0; cpu.loH=c.loH|0;\x0d\n  cpu._compareArmed=c.compareArmed; cpu._lastFiredCompare=c.lastFiredCompare;\x0d\n  cpu.instructionCount=c.instructionCount;\x0d\n  cpu.isHleBootDone=c.isHleBootDone; cpu.isRunning=c.isRunning;\x0d\n  cpu.branchTaken=c.branchTaken; cpu.branchTarget=c.branchTarget|0;\x0d\n  cpu.tlbEntries=c.tlb.map(e=>e?{pageMask:e.pageMask\x2CentryHi:e.entryHi\x2CentryLo0:e.entryLo0\x2CentryLo1:e.entryLo1}:null);\x0d\n  cpu.fetchPage=-1; cpu.fetchView=null;\x0d\n  const mm=m.mmu;\x0d\n  mmu.viRegisters.set(mm.vi); mmu.miRegisters.set(mm.mi); mmu.piRegisters.set(mm.pi);\x0d\n  mmu.siRegisters.set(mm.si); mmu.spRegisters.set(mm.sp); mmu.dpcRegisters.set(mm.dpc);\x0d\n  mmu.aiRegisters.set(mm.ai); mmu.riRegisters.set(mm.ri);\x0d\n  mmu.pifRam.set(Buffer.from(mm.pifRam\x2C'base64'));\x0d\n  mmu.eeprom.set(Buffer.from(mm.eeprom\x2C'base64'));\x0d\n  mmu.spDmem.set(Buffer.from(mm.spDmem\x2C'base64'));\x0d\n  mmu.spImem.set(Buffer.from(mm.spImem\x2C'base64'));\x0d\n  mmu.piBusyUntil=mm.piBusyUntil; mmu.siBusyUntil=mm.siBusyUntil;\x0d\n  mmu.aiBusyUntil=mm.aiBusyUntil; mmu.aiQueuedDuration=mm.aiQueuedDuration;\x0d\n  mmu.viNextInterrupt=mm.viNextInterrupt; mmu.siDmaDirection=mm.siDmaDirection;\x0d\n  mmu.siDramAddr=mm.siDramAddr; mmu.buttons=mm.buttons; mmu.stickX=mm.stickX; mmu.stickY=mm.stickY;\x0d\n  return m;\x0d\n}\x0d\nmodule.exports={saveState\x2CloadState};\x0d\n
