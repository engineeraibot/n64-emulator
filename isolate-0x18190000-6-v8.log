ange stays inside RDRAM (read8 would wrap at 0x800000 \u2014 rare;\n        // fall back for that). This was 16.8% of total JS time in-game.\n        const copyLen = Math.min(totalBytes\x2C 4096 - off);\n        if (copyLen > 0 && srcBase + copyLen <= 0x800000) {\n            let r8 = this._rdram8;\n            if (!r8 || r8.buffer !== this.mmu.memory.rdram) {\n                r8 = this._rdram8 = new Uint8Array(this.mmu.memory.rdram);\n            }\n            this.tmem.set(r8.subarray(srcBase\x2C srcBase + copyLen)\x2C off);\n        } else {\n            for (let i = 0; i < totalBytes && (off + i < 4096); i++) {\n                this.tmem[off + i] = this.mmu.read8(srcBase + i);\n            }\n        }\n    }\n\n    handleG_LOADTILE(hi\x2C lo) {\n        const t = (lo >> 24) & 0x7;\n        const uls = (hi >>> 12) & 0xFFF\x2C ult = hi & 0xFFF;\n        const lrs = (lo >>> 12) & 0xFFF\x2C lrt = lo & 0xFFF;\n        const tile = this.rspState.tiles[t];\n        const off = tile.tmem * 8;\n        const bpp = (this.rspState.textureImageSize === 3) ? 4 : (this.rspState.textureImageSize === 2 ? 2 : 1);\n        const imgWidth = this.rspState.textureImageWidth;\n\n        // Each TMEM row must start on the tile's line-word boundary\x2C matching the\n        // sampler's row stride (tt * tile.line * 8 bytes). The old loader packed\n        // rows CONTIGUOUSLY (single d++)\x2C which is only correct when the loaded\n        // row width exactly fills tile.line words. MK64 loads its menu background\n        // in 321-wide RGBA16 strips with line=81 words (324 texels): 642 bytes of\n        // data per 648-byte row\x2C so contiguous packing drifted every row by 3\n        // texels -> diagonal striping. Honoring lineBytes fixes it and is\n        // byte-identical wherever row bytes == tile.line*8 (e.g. SM64). Flat TMEM\n        // (no odd-line word swizzle) is preserved\x2C consistent with the sampler.\n        const x0 = Math.floor(uls / 4)\x2C x1 = Math.floor(lrs / 4);\n        const y0 = Math.floor(ult / 4)\x2C y1 = Math.floor(lrt / 4);\n        const lineBytes = (tile.line | 0) > 0 ? tile.line * 8 : (x1 - x0 + 1) * bpp;\n        for (let y = y0; y <= y1; y++) {\n            let s = this.rspState.textureImage + (y * imgWidth + x0) * bpp;\n            let d = off + (y - y0) * lineBytes;\n            for (let x = x0; x <= x1 && d < 4096; x++) {\n                for (let b = 0; b < bpp && d < 4096; b++) {\n                    this.tmem[d++] = this.mmu.read8(s++);\n                }\n            }\n        }\n    }\n\n    handleG_LOADTLUT(hi\x2C lo) {\n        // G_LOADTLUT (0xF0): load 16-bit palette entries from the current\n        // texture image (SETTIMG) into the TLUT half of TMEM. Hardware stores\n        // entry i 4x-replicated at word (tile.tmem + i); our CI sampler reads a\n        // FLAT layout (2 bytes/entry from byte 2048\x2C CI4 palettes 16 entries =\n        // 32 bytes apart: palOff = 2048 + (palette*16 + idx)*2). So flat-pack:\n        // entry i -> byte 2048 + ((tile.tmem - 256) + i) * 2\x2C which makes both\n        // the full-256 CI8 TLUT (tmem=256) and per-palette CI4 loads\n        // (tmem=256+pal*16) land exactly where the sampler looks. RGBA16 TLUT\n        // assumed (SM64 uses G_TT_RGBA16; IA16 TLUTs would need otherModeHi\n        // bit 15..14 == 3 handling in the sampler).\n        const t = (lo >> 24) & 0x7;\n        if (t >= 8) return;\n        const tile = this.rspState.tiles[t];\n        const uls = (hi >>> 12) & 0xFFF;          // 10.2 fixed\n        const lrs = (lo >>> 12) & 0xFFF;\n        const first = uls >> 2\x2C last = lrs >> 2;\n        const count = Math.max(0\x2C Math.min(256\x2C last - first + 1));\n        if (!this.rspState.textureImage || count === 0) return;\n        const srcBase = (this.rspState.textureImage + first * 2) & 0x7FFFFF;\n        const entryBase = (tile.tmem >= 256 ? tile.tmem - 256 : tile.tmem) & 0x1FF;\n        for (let i = 0; i < count; i++) {\n            const 