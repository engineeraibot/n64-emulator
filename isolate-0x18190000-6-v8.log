h (n * 16)\x2C\n            // and destination vertex is encoded in the low nibble of bits 16..23.\n            num = ((hi & 0xFFFF) >>> 4) & 0x3F;\n            dest = (hi >>> 16) & 0xF;\n        }\n        if (dest < 0) dest = 0;\n        if (num <= 0) return;\n        const addr = this.resolveAddress(lo);\n        const mv = this.rspState.modelviewStack[this.rspState.modelviewStack.length - 1];\n        const p = this.rspState.projectionMatrix;\n        // libultra is row-vector: v' = v * MV * P. Composition MVP = MV * P.\n        // multiplyMatrices(a\x2C b) computes (A*B)[r][c] = sum_k A[r][k] * B[k][c]\x2C\n        // which is exactly MV*P when called as (mv\x2C p).\n        const mvp = this.multiplyMatrices(mv\x2C p);\n\n        // G_LIGHTING (0x00020000 on both Fast3D and F3DEX2): when set\x2C bytes\n        // 12..14 of each vertex hold a signed normal\x2C not RGB. We compute the\n        // shade per-vertex using ambient + N\xb7L for any configured lights\x2C or a\n        // sensible default if the game hasn't sent any lights yet.\n        const lightingOn = (this.rspState.geometryMode & 0x00020000) !== 0;\n        // G_TEXTURE_GEN (0x40000) / G_TEXTURE_GEN_LINEAR (0x80000): MK64 and\n        // many games env-map shiny surfaces \u2014 the RSP synthesizes texcoords\n        // from the modelview-transformed vertex normal instead of using the\n        // stored (zero) s/t. SM64 never set these bits.\n        const texgenOn = (this.rspState.geometryMode & 0x00040000) !== 0;\n        const texgenLinear = (this.rspState.geometryMode & 0x00080000) !== 0;\n\n        for (let i = 0; i < num; i++) {\n            const v = addr + i * 16;\n            const x = (this.mmu.read16(v) << 16) >> 16;\n            const y = (this.mmu.read16(v + 2) << 16) >> 16;\n            const z = (this.mmu.read16(v + 4) << 16) >> 16;\n            // Row-vector v_row * MVP: output[c] = sum_r v[r] * mvp[r*4+c].\n            // With v = (x\x2C y\x2C z\x2C 1)\x2C this picks the c-th *column* of MVP.\n            const tx = x*mvp[0] + y*mvp[4] + z*mvp[8]  + mvp[12];\n            const ty = x*mvp[1] + y*mvp[5] + z*mvp[9]  + mvp[13];\n            const tz = x*mvp[2] + y*mvp[6] + z*mvp[10] + mvp[14];\n            const tw = x*mvp[3] + y*mvp[7] + z*mvp[11] + mvp[15];\n\n            // Pre-divide screen coords for the common all-in-front case. We also\n            // keep the clip-space coords (cx\x2C cy\x2C cz\x2C cw) on the vertex so\n            // drawTriangle can do real near-plane clipping in clip space before\n            // any perspective divide on partially-clipped triangles.\n            const proj = this.projectClipToScreen(tx\x2C ty\x2C tz\x2C tw);\n\n            let r\x2C g\x2C b;\n            const a = this.mmu.read8(v + 15);\n            // Normal needed for lighting and/or texgen.\n            let _nx = 0\x2C _ny = 0\x2C _nz = 0;\n            if (lightingOn || texgenOn) {\n                _nx = ((this.mmu.read8(v + 12) << 24) >> 24) / 127.0;\n                _ny = ((this.mmu.read8(v + 13) << 24) >> 24) / 127.0;\n                _nz = ((this.mmu.read8(v + 14) << 24) >> 24) / 127.0;\n            }\n            if (lightingOn) {\n                const shade = this.computeLitShade(_nx\x2C _ny\x2C _nz);\n                r = shade.r; g = shade.g; b = shade.b;\n            } else {\n                r = this.mmu.read8(v + 12);\n                g = this.mmu.read8(v + 13);\n                b = this.mmu.read8(v + 14);\n            }\n            // Default: stored texcoords (S10.5). Texgen overrides below.\n            let vS = (this.mmu.read16(v + 8) << 16) >> 16;\n            let vT = (this.mmu.read16(v + 10) << 16) >> 16;\n            if (texgenOn) {\n                // Transform the normal by the modelview rotation (row-vector\n                // n*MV) and normalize. Dot against the look-at axes (default\n                // X and Y) to get the spherical env-map coordinate.\n                const tnx = _nx*mv[0] + _ny*mv[4] + _nz*mv[8];\n                const tny = _nx*mv[1] + _ny*mv[5] + _nz*mv[9];\n                const tnz = _nx*mv[2] + _ny*mv[6] + _nz*mv[10];\n                let len = Math.sqrt(tnx*tnx + tny*tny + tnz*tnz);\n                if (len < 1e-6) len = 1;\n                const ux = tnx/len\x2C uy = tny/len;\n                const SPAN = this.rspState.texgenSpan || 0x8000;\n                if (texgenLinear) {\n                    const cx = ux < -1 ? -1 : ux > 1 ? 1 : ux;\n                    const cy = uy < -1 ? -1 : uy > 1 ? 1 : uy;\n                    vS = (Math.acos(cx) / Math.PI) * SPAN;\n                    vT = (Math.acos(cy) / Math.PI) * SPAN;\n                } else {\n                    vS = (ux * 0.5 + 0.5) * SPAN;\n                    vT = (uy * 0.5 + 0.5) * SPAN;\n                }\n            }\n\n            // G_FOG (0x00010000): RSP replaces shade alpha with the per-vertex\n            // fog factor computed from clip-space z/w (NDC z\x2C +1 = far plane).\n            let va = a;\n            if ((this.rspState.geometryMode & 0x00010000) !== 0) {\n                let ndcZ = (Math.abs(tw) > 1e-6) ? tz / tw : 1.0;\n                if (ndcZ > 1.0) ndcZ = 1.0; else if (ndcZ < -1.0) ndcZ = -1.0;\n                let f = ndcZ * this.rspState.fogMul + this.rspState.fogOff;\n                va = f <= 0 ? 0 : f >= 255 ? 255 : (f | 0);\n            }\n\n            this.rspState.vertices[dest + i] = {\n                x: proj.sx\x2C y: proj.sy\x2C z: proj.sz\x2C w: tw\x2C\n                cx: tx\x2C cy: ty\x2C cz: tz\x2C cw: tw\x2C\n                r\x2C g\x2C b\x2C a: va\x2C\n                s: vS\x2C t: vT\x2C\n                _needsProject: false\n            };\n        }\n    }\n\n    // Compute lit shade for a vertex normal. Returns {r\x2C g\x2C b} in [0\x2C 255].\n    // Uses configured lights (from G_MOVEMEM index G_MV_L0..7 + ambient slot)\n    // if present\x2C otherwise falls back to a default ambient + key light so\n    // SM64's Mario isn't pitch-black before the game finishes setting up lights.\n    computeLitShade(nx\x2C ny\x2C nz) {\n        const lights = this.rspState.lights;\n        const numLights = this.rspState.numLights | 0;\n        let ambR\x2C ambG\x2C ambB;\n        let dirLights;\n        if (lights && numLights > 0 && lights[numLights]) {\n            const amb = lights[numLights];\n            ambR = amb.r; ambG = amb.g; ambB = amb.b;\n            dirLights = lights.slice(0\x2C numLights);\n        } else {\n            // Default: warm ambient + one front-up key light. Matches what the\n            // SM64 boot intro looks like before the game's own light setup\n            // takes over.\n            ambR = 64; ambG = 64; ambB = 64;\n            dirLights = [{ r: 200\x2C g: 200\x2C b: 200\x2C dx: 0.4\x2C dy: 0.7\x2C dz: 0.6 }];\n        }\n        let R = ambR\x2C G = ambG\x2C B = ambB;\n        for (const L of dirLights) {\n            const dot = nx * L.dx + ny * L.dy + nz * L.dz;\n            const k = dot > 0 ? dot : 0;\n            R += L.r * k;\n            G += L.g * k;\n            B += L.b * k;\n        }\n        return {\n            r: R > 255 ? 255 : (R < 0 ? 0 : R | 0)\x2C\n            g: G > 255 ? 255 : (G < 0 ? 0 : G | 0)\x2C\n            b: B > 255 ? 255 : (B < 0 ? 0 : B | 0)\n        };\n    }\n\n    // Apply perspective divide + viewport mapping to a clip-space vertex.\n    // Returns {sx\x2C sy\x2C sz}. Safe against tw == 0.\n    //\n    // libultra's perspective matrix (row-vector convention):\n    //   tw = -z_eye   (positive for objects in front of camera)\n    //   tz/tw = NDC_z \u2208 [-1\x2C 1] for the near/far range\n    //\n    // Depth mapping: sz = (NDC_z + 1) / 2  maps [-1\x2C+1] \u2192 [0\x2C1]\n    //   near plane (NDC_z = -1)  \u2192  sz = 0   \u2192  zFixed = 0\n    //   far plane  (NDC_z = +1)  \u2192  sz = 1   \u2192  zFixed = 0xFFFF\n    //\n    // This gives proper depth ordering as long as the depth buffer is cleared\n    // to 0xFFFF (far) via G_FILLRECT before each frame