xFFFF; // bytes\n        const addr = this.audioSegAddr(w1);\n        const lim = this.mmu.memory.rdram.byteLength;\n        const n16 = Math.min(count >> 1\x2C this.audioADPCMTable.length);\n        for (let i = 0; i < n16; i++) {\n            const a = addr + i * 2;\n            this.audioADPCMTable[i] = (a + 1 < lim) ? rd.getInt16(a\x2C false) : 0;\n        }\n    }\n\n    // The binary F3D/F3DEX2 flavor flag is not enough: F3DEX 1.x (e.g. Mario\n    // Kart 64) shares F3D's high-opcode encoding (0xBF/0xB1/0xB5) but scales\n    // triangle vertex indices by 2\x2C where classic F3D (Super Mario 64) scales\n    // by 10. Pick the scale by scanning triangle command index bytes:\n    //   - any index byte > 62  => F3D (16-vert cache\x2C idx*10\x2C bytes up to 150)\n    //   - else any byte not a multiple of 10 => F3DEX 1.x (32-vert cache\x2C idx*2)\n    //   - else default to F3D (Super-Mario-64-safe).\n    detectMicrocodeTriScale(addr\x2C dataSize) {\n        // Authoritative microcode identification: every Gfx ucode embeds an\n        // ASCII version string in its ucode_data segment (OSTask+0x18). This is\n        // far more reliable than guessing from display-list bytes.\n        //   "RSP SW Version: 2.0D ..."        -> Fast3D / F3D  (SM64)   idx*10\n        //   "F3DEX        0.95 ..."           -> F3DEX 1.x     (MK64)   idx*2\n        //   "F3DZEX NoN fifo 2.06H ..."       -> F3DEX2 gen    (OoT)    idx*2\n        let name = '';\n        try {\n            const ucd = this.mmu.spDmemView.getUint32(0xFC0 + 0x18\x2C false) >>> 0;\n            const base = ucd & 0x7FFFFF;\n            const rd = new Uint8Array(this.mmu.memory.rdram);\n            let buf = '';\n            for (let k = 0; k < 0x800; k++) {\n                const c = rd[(base + k) & 0x7FFFFF];\n                buf += (c >= 32 && c < 127) ? String.fromCharCode(c) : '\\n';\n            }\n            const m = buf.match(/(F3DZEX|F3DEX2|S2DEX2|F3DLX2|F3DEX|F3DLX|F3DLP|S2DEX|L3DEX|Fast3D|RSP SW Version)[^\\n]*/);\n            if (m) name = m[0].trim();\n        } catch (e) { /* fall through to opcode-scan result */ }\n\n        if (name) {\n            // Generation-2 ucodes (F3DEX2 family\x2C incl. Zelda's F3DZEX): idx*2\x2C\n            // EX2 command encoding (0x05 G_TRI1\x2C 0xDE G_DL\x2C ...).\n            if (/F3DZEX|F3DEX2|S2DEX2|F3DLX2/.test(name)) {\n                this.rspState.isF3DEX2 = true; this.rspState.triIndexScale = 2;\n            } else if (/F3DEX|F3DLX|S2DEX|L3DEX/.test(name)) {\n                // F3DEX 1.x: F3D-style opcodes (0xBF/0xB1/0xB5) but idx*2.\n                this.rspState.isF3DEX2 = false; this.rspState.triIndexScale = 2;\n            } else {\n                // Fast3D / classic F3D: idx*10.\n                this.rspState.isF3DEX2 = false; this.rspState.triIndexScale = 10;\n            }\n            this.rspState.ucodeName = name.split(/[ \\t]/)[0] || name;\n            return;\n        }\n        // No string found: trust the opcode-scan flavor flag.\n        this.rspState.triIndexScale = this.rspState.isF3DEX2 ? 2 : 10;\n        this.rspState.ucodeName = this.rspState.isF3DEX2 ? 'F3DEX2' : 'F3D';\n    }\n\n    detectDisplayListFlavor(addr\x2C dataSize\x2C ucodeSize) {\n        // Prefer a lightweight opcode scan and bias unknown streams toward Fast3D.\n        // SM64 command streams are Fast3D-heavy (0xBF TRI1\x2C 0x04 VTX\x2C etc.).\n        const maxScanCommands = dataSize > 0 ? Math.min(96\x2C (dataSize + 7) >>> 3) : 64;\n        let f3dex2Signals = 0;\n        let f3dSignals = 0;\n        let pc = addr >>> 0;\n\n        for (let i = 0; i < maxScanCommands; i++) {\n            const hi = this.mmu.read32(Number(pc));\n            const op = (hi >>> 24) & 0xFF;\n            // Strong F3DEX2 style opcodes.\n            if (op === 0xDE || op === 0xDF || op === 0xDA || op === 0xD9 || op === 0xD8) {\n                f3dex2Signals += 2;\n            }\n            if (op === 0x05) f3dex2Signals++;\n\n            // Strong Fast