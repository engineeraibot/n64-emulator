== 0;\n                    this.recomputeUseTexture();\n                    break;\n                case 0xFA: this.rspState.primColor = lo; break;\n                case 0xFB: this.rspState.envColor = lo; break;\n                case 0xF9: this.rspState.blendColor = lo; break;\n                case 0xF8: this.rspState.fogColor = lo; break;\n                case 0xD9: {\n                    // F3DEX2 G_GEOMETRYMODE: w0 low 24 bits hold ~clearbits\x2C w1\n                    // holds setbits. The RSP computes\n                    //   mode = (mode & ~clearbits) | setbits.\n                    // The old `|= lo` only ever SET bits and never cleared them\x2C\n                    // so CULL_FRONT (0x200) and CULL_BACK (0x400) accumulated\n                    // into CULL_BOTH and drawTriangle culled EVERY OoT triangle\n                    // (0 px rendered). SM64 (F3D) and MK64 (F3DEX 1.x) use the\n                    // separate 0xB6/0xB7 set/clear commands\x2C not 0xD9\x2C so they\n                    // are byte-identical (Task #55).\n                    if (this.rspState.isF3DEX2) {\n                        const clearMask = (~hi) & 0x00FFFFFF;\n                        this.rspState.geometryMode = (this.rspState.geometryMode & ~clearMask) | lo;\n                    } else {\n                        this.rspState.geometryMode |= lo;\n                    }\n                    break;\n                }\n                case 0xB8: // ENDDL in F3D/F3DEX2\n                    if (depth > 0) { depth--; pc = stack.pop(); }\n                    else {\n                        this.displayListReturnCount++;\n                        return;\n                    }\n                    break;\n                case 0xE7: case 0xE6: case 0xE8: break; // Syncs\n                case 0xE9: // FULLSYNC\n                    this.mmu.miRegisters[2] |= 0x20;\n                    this.mmu.updateInterrupts();\n                    break;\n                case 0xF0: this.handleG_LOADTLUT(hi\x2C lo); break;\n            }\n        }\n        if (cmdCount >= maxCommands) this.displayListAbortCount++;\n    }\n\n    createIdentityMatrix() { return [1\x2C0\x2C0\x2C0\x2C 0\x2C1\x2C0\x2C0\x2C 0\x2C0\x2C1\x2C0\x2C 0\x2C0\x2C0\x2C1]; }\n\n    multiplyMatrices(a\x2C b) {\n        // Row-major 4x4 multiply: res = a * b where a\x2C b\x2C res use a[row*4+col].\n        // (libultra's readMatrix produces a row-major flat array.)\n        const res = new Array(16).fill(0);\n        for (let r = 0; r < 4; r++) {\n            for (let c = 0; c < 4; c++) {\n                res[r * 4 + c] =\n                    a[r * 4 + 0] * b[0 * 4 + c] +\n                    a[r * 4 + 1] * b[1 * 4 + c] +\n                    a[r * 4 + 2] * b[2 * 4 + c] +\n                    a[r * 4 + 3] * b[3 * 4 + c];\n            }\n        }\n        return res;\n    }\n\n    readMatrix(addr) {\n        // libultra Mtx layout: two 32-byte halves (integer\x2C then fractional).\n        // Each half stores 16 16-bit values laid out as `s32 m[8][2]`\x2C i.e.\n        // bytes 0-3 = (M[0][0]_int\x2C M[0][1]_int)\x2C bytes 4-7 = (M[0][2]_int\x2C\n        // M[0][3]_int)\x2C bytes 8-11 = (M[1][0]_int\x2C M[1][1]_int)\x2C etc.\n        // Returned flat array is row-major: m[row*4 + col] = M[row][col].\n        const m = new Array(16);\n        for (let row = 0; row < 4; row++) {\n            for (let pair = 0; pair < 2; pair++) {\n                const idx = row * 2 + pair;\n                const hiWord = this.mmu.read32(addr + idx * 4) >>> 0;\n                const loWord = this.mmu.read32(addr + 32 + idx * 4) >>> 0;\n                const fixed0 = (((hiWord & 0xFFFF0000) >>> 0) | (loWord >>> 16)) | 0;\n                const fixed1 = ((((hiWord & 0xFFFF) << 16) >>> 0) | (loWord & 0xFFFF)) | 0;\n                m[row * 4 + pair * 2] = fixed0 / 65536.0;\n                m[row * 4 + pair * 2 + 1] = fixed1 / 65536.0;\n            }\n        }\n        return m;\n    }\n\n    resolveAddress(addr) {\n        