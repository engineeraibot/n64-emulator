= this.rspState.vertices[((((lo >> 16) & 0xFF) / s) | 0)];\n        const v5 = this.rspState.vertices[((((lo >> 8) & 0xFF) / s) | 0)];\n        const v6 = this.rspState.vertices[((lo & 0xFF) / s) | 0];\n        if (v4 && v5 && v6) this.drawTriangle(v4\x2C v5\x2C v6);\n    }\n\n    handleG_MOVEMEM(hi\x2C lo) {\n        const idx = (hi >>> 16) & 0xFF;\n        const addr = this.resolveAddress(lo);\n        // Viewport (Fast3D: 0x80\x2C F3DEX2: 0x08\x2C plus the legacy 0x01 alias).\n        if (idx === 0x01 || idx === 0x08 || idx === 0x80) {\n            this.rspState.viewport = {\n                scale: [((this.mmu.read16(addr) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 2) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 4) << 16) >> 16) / 512.0]\x2C\n                trans: [((this.mmu.read16(addr + 8) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 10) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 12) << 16) >> 16) / 512.0]\n            };\n            return;\n        }\n        // Fast3D lights: G_MV_L0=0x86\x2C L1=0x88\x2C ...\x2C L7=0x94. The slot for\n        // the ambient term is index (numLights*2 + 0x86). The Light_t / Ambient_t\n        // layouts share the same first 4 bytes (RGB + pad)\x2C so we read those\n        // unconditionally and only pull dir bytes when present.\n        if (idx >= 0x86 && idx <= 0x94 && ((idx - 0x86) & 1) === 0) {\n            const slot = (idx - 0x86) >>> 1;\n            if (slot >= 0 && slot < 8) {\n                const r = this.mmu.read8(addr + 0);\n                const g = this.mmu.read8(addr + 1);\n                const b = this.mmu.read8(addr + 2);\n                // Direction bytes live at +8..+10 as signed 8-bit. Normalize so\n                // we don't depend on the game to provide a unit vector exactly.\n                const dxRaw = (this.mmu.read8(addr + 8) << 24) >> 24;\n                const dyRaw = (this.mmu.read8(addr + 9) << 24) >> 24;\n                const dzRaw = (this.mmu.read8(addr + 10) << 24) >> 24;\n                let dx = dxRaw / 127\x2C dy = dyRaw / 127\x2C dz = dzRaw / 127;\n                const m = Math.sqrt(dx*dx + dy*dy + dz*dz);\n                if (m > 1e-6) { dx /= m; dy /= m; dz /= m; }\n                if (!this.rspState.lights) this.rspState.lights = new Array(8).fill(null);\n                this.rspState.lights[slot] = { r\x2C g\x2C b\x2C dx\x2C dy\x2C dz };\n            }\n            return;\n        }\n        // F3DEX2 single light slot (G_MV_LIGHT = 0x0A). Address encodes the\n        // sub-slot in upper bits of `lo`; for now treat as light 0.\n        if (idx === 0x0A) {\n            const r = this.mmu.read8(addr + 0);\n            const g = this.mmu.read8(addr + 1);\n            const b = this.mmu.read8(addr + 2);\n            const dxRaw = (this.mmu.read8(addr + 8) << 24) >> 24;\n            const dyRaw = (this.mmu.read8(addr + 9) << 24) >> 24;\n            const dzRaw = (this.mmu.read8(addr + 10) << 24) >> 24;\n            let dx = dxRaw / 127\x2C dy = dyRaw / 127\x2C dz = dzRaw / 127;\n            const m = Math.sqrt(dx*dx + dy*dy + dz*dz);\n            if (m > 1e-6) { dx /= m; dy /= m; dz /= m; }\n            if (!this.rspState.lights) this.rspState.lights = new Array(8).fill(null);\n            this.rspState.lights[0] = { r\x2C g\x2C b\x2C dx\x2C dy\x2C dz };\n            return;\n        }\n    }\n\n    // F3DEX2 G_MOVEMEM (cmd 0xDC). The wire layout differs from Fast3D: the\n    // destination index lives in the LOW byte of w0 (hi & 0xFF) and the byte\n    // offset within that buffer in the next byte ((hi>>8)&0xFF)*8 -- NOT the\n    // Fast3D (hi>>16)&0xFF layout that handleG_MOVEMEM decodes. Gated to the\n    // F3DEX2 dispatch only\x2C so SM64/MK64 paths are untouched.\n    handleG_MOVEMEM_EX2(hi\x2C lo) {\n        const idx = hi & 0xFF;\n        const ofs = ((hi >>> 8) & 0xFF) * 8;\n        const addr = this.resolveAddress(lo);\n        if (idx === 0x08) { // G_MV_VIEWPORT -- Vp { s16 vscale[4]; s16 vtrans[4]; }\n            this.rspState.viewport = {\n                scale: [((this.mmu.read16(addr) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 2) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 4) << 16) >> 16) / 512.0]\x2C\n                trans: [((this.mmu.read16(addr + 8) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 10) << 16) >> 16) / 4.0\x2C ((this.mmu.read16(addr + 12) << 16) >> 16) / 512.0]\n            };\n            return;\n        }\n        if (idx === 0x0A) { // G_MV_LIGHT\n            // F3DEX2 DMEM light buffer layout (gbi2 G_MVO_* offsets): the unit\n            // ofs/24 is 0 = LOOKATX\x2C 1 = LOOKATY (texgen look-at vectors\x2C NOT\n            // lights)\x2C then L0 at 2*24=48\x2C L1 at 72\x2C ... so the diffuse-light\n            // slot is unit-2. The ambient term is the entry one past the diffuse\n            // lights (slot == numLights)\x2C which computeLitShade reads as\n            // lights[numLights]. The OLD decode (slot = ofs/24 - 1) treated\n            // LOOKATY (rgb 0\x2C128\x2C0) as a bogus GREEN up-light in slot 0 and\n            // shifted L0/L1/ambient up one\x2C so OoT rooms were green-tinted and\n            // used the wrong (warm) colour as "ambient" (Task #58).\n            const unit = (ofs / 24) | 0;\n            const r = this.mmu.read8(addr + 0)\x2C g = this.mmu.read8(addr + 1)\x2C b = this.mmu.read8(addr + 2);\n            const dxRaw = (this.mmu.read8(addr + 8) << 24) >> 24;\n            const dyRaw = (this.mmu.read8(addr + 9) << 24) >> 24;\n            const dzRaw = (this.mmu.read8(addr + 10) << 24) >> 24;\n            let dx = dxRaw / 127\x2C dy = dyRaw / 127\x2C dz = dzRaw / 127;\n            const m = Math.sqrt(dx * dx + dy * dy + dz * dz);\n            if (m > 1e-6) { dx /= m; dy /= m; dz /= m; }\n            if (unit < 2) {\n                // LOOKATX / LOOKATY -- keep for texgen\x2C do not pollute lights.\n                if (!this.rspState.lookat) this.rspState.lookat = [null\x2C null];\n                this.rspState.lookat[unit] = { dx\x2C dy\x2C dz };\n                return;\n            }\n            const slot = unit - 2;\n            if (slot >= 0 && slot < 8) {\n                if (!this.rspState.lights) this.rspState.lights = new Array(8).fill(null);\n                this.rspState.lights[slot] = { r\x2C g\x2C b\x2C dx\x2C dy\x2C dz };\n            }\n            return;\n        }\n    }\n\n    handleG_MTX(hi\x2C lo) {\n        const m = this.readMatrix(this.resolveAddress(lo));\n        if (this.rspState.isF3DEX2) {\n            // F3DEX2 (gbi2) gSPMatrix packs the param byte in the LOW 8 bits of\n            // w0 (NOT bits 16..23 like Fast3D)\x2C and the macro XORs it with\n            // G_MTX_PUSH. So on the wire:\n            //   0x04 = PROJECTION (vs MODELVIEW)\x2C 0x02 = LOAD (vs MUL)\x2C\n            //   0x01 = NOPUSH  (PUSH when this bit is CLEAR\x2C due to the XOR).\n            // The old decode read (hi>>>16)&0xFF (always 0 for the 0xDA cmd)\x2C so\n            // EVERY OoT matrix was treated as modelview-MUL-nopush -> the camera\n            // / projection matrices got multiplied into the single modelview\n            // entry every frame\x2C exploding it (|elems| ~1e15) -> all vertices\n            // collapsed to the viewport centre (Task #55).\n            const f = hi & 0xFF;\n            const isLoad = (f & 0x02) !== 0;\n            if (f & 0x04) {\n                this.rspState.projectionMatrix = isLoad ? m\n                    : this.multiplyMatrices(m\x2C this.rspState.projectionMatrix);\n            } else {\n                const cur = this.rspState.modelviewStack[this.rspState.modelviewStack.length - 1];\n                const next = isLoad ? m : this.multiplyMatrices(m\x2C cur);\n                if ((f & 0x01) === 0) this.rspState.modelviewStack.push(next); // PUSH\n                else this.rspState.modelviewStack[this.rspState.modelviewStack.length - 1] = next;\n            }\n            return;\n        }\n        // ---- Fast3D (F3D: SM64; and F3DEX 1.x cmd 0x01: MK64) \u2014 UNCHANGED ----\n        // Matrix flags live in bits 16..23 (not the low byte\x2C which is usually length).\n        const f = (hi >>> 16) & 0xFF;\n        if (f & 0x01) {\n            if (f & 0x02) this.rspState.projectionMatrix = m;\n            // G_MTX_MUL premultiplies: with row vectors (v' = v*M)\x2C the incoming\n            // matrix applies to the vertex FIRST\x2C so top' = m * top (Task #43).\n            else this.rspState.projectionMatrix = this.multiplyMatrices(m\x2C this.rspState.projectionMatrix);\n        } else {\n            let cur = this.rspState.modelviewStack[this.rspState.modelviewStack.length - 1];\n            // G_MTX_MUL: top' = m * top\x2C NOT top * m. The old order applied the\n            // incoming matrix in eye space; SM64's castle paintings (the only\n            // heavy G_MTX_MUL chain user: translate*rotX*rotY*scale) rendered\n            // hundreds of pixels off-screen\x2C leaving a black hole (Task #43).\n            let next = (f & 0x02) ? m : this.multiplyMatrices(m\x2C cur);\n            // Fast3D gbi has NO XOR in gSPMatrix (the XOR trick is F3DEX2-only)\x2C\n            // so at the command level bit 2 SET means G_MTX_PUSH directly. The\n            // old inverted decode pushed on every LOAD (stack grew unboundedly\x2C\n            // observed depth 60+) and never pushed for the painting's\n            // MUL|PUSH translate (Task #43).\n            const isPush = (f & 0x04) !== 0;\n            if (isPush) this.rspState.modelviewStack.push(next);\n            else this.rspState.modelviewStack[this.rspState.modelviewStack.length - 1] = next;\n        }\n    }\n\n    handleG_FILLRECT(hi\x2C lo) {\n        this.drawStats.fillRects++;\n        // G_FILLRECT is a flat fill ONLY in FILL (3) and COPY (2) cycle modes.\n        // In 1-/2-cycle mode (0/1) it rasterizes a rectangle through the\n        // combiner+blender (games use this for full-screen fades/overlays). Our\n        //