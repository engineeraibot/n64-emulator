                    if (depth > 0) { depth--; pc = stack.pop(); }\n                    else {\n                        this.displayListReturnCount++;\n                        return;\n                    }\n                    break;\n                case 0xDA: this.handleG_MTX(hi\x2C lo); break;\n                case 0xD7: { // G_TEXTURE (F3DEX2): on=bits1-7\x2C tile=bits8-10\x2C level=bits11-13\n                    // Was UNDISPATCHED for F3DEX2 (Task #56) -> textureEnabled never\n                    // set -> useTexture always false -> every OoT triangle flat-shaded.\n                    // SM64/MK64 send G_TEXTURE as 0xBB (untouched)\x2C so byte-identical.\n                    this.rspState.textureScaleS = (lo >>> 16) / 65536.0;\n                    this.rspState.textureScaleT = (lo & 0xFFFF) / 65536.0;\n                    this.rspState.currentTile = (hi >>> 8) & 0x7;\n                    this.rspState.textureEnabled = ((hi >>> 1) & 0x7F) !== 0;\n                    this.recomputeUseTexture();\n                    break;\n                }\n                case 0xDC: // G_MOVEMEM (F3DEX2): index=hi&0xFF\x2C offset=((hi>>8)&0xFF)*8\n                    // Was UNDISPATCHED for F3DEX2 (Task #56) -> viewport (idx 8) never\n                    // captured -> projectClipToScreen used the 160/120 default scale and\n                    // OoT geometry spilled off-screen. SM64 sends G_MOVEMEM as 0x03.\n                    this.handleG_MOVEMEM_EX2(hi\x2C lo);\n                    break;\n                case 0xD8: if (this.rspState.modelviewStack.length > 1) this.rspState.modelviewStack.pop(); break;\n                case 0x04: this.handleG_VTX(hi\x2C lo); break;\n                case 0xBF: this.handleG_TRI1(hi\x2C lo\x2C this.rspState.isF3DEX2); break;\n                case 0xB1: this.handleG_TRI2(hi\x2C lo\x2C this.rspState.isF3DEX2); break;\n                case 0xB5: this.handleG_TRI2(hi\x2C lo\x2C this.rspState.isF3DEX2); break; // G_QUAD (F3D/F3DEX) = 2 tris (v0v1v