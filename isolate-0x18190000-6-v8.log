return;\n        }\n        this.recordVideoWrite('fill');\n        // RDP G_FILLRECT: the rect goes from (x1\x2C y1) to (x2\x2C y2) INCLUSIVE on\n        // both ends in 10.2 fixed point. The previous version used `<` for the\n        // upper bound which dropped the last row/column \u2014 visible as a 1-pixel\n        // unfilled strip at the bottom/right of every cleared framebuffer (and\n        // worse\x2C an unfilled 1-pixel strip of the Z buffer that always failed\n        // the depth test).\n        const x2 = (hi >>> 12) & 0xFFF\x2C y2 = hi & 0xFFF\x2C x1 = (lo >>> 12) & 0xFFF\x2C y1 = lo & 0xFFF;\n        const addr = this.rspState.colorImage;\n        if (!addr && addr !== 0) return;\n        if (this.rspState.colorImageWidth <= 0) return;\n        const rd = new DataView(this.mmu.memory.rdram);\n        const sz = this.rspState.colorImageSize;\n        const w = this.rspState.colorImageWidth;\n\n        const bpp = (sz === 3) ? 4 : (sz === 2 ? 2 : 1);\n        // For 16-bit fills\x2C the N64 RDP writes two pixels per cycle using the\n        // 32-bit fillColor split into a high and a low half. Most game code\n        // packs the same value in both halves (so it doesn't matter which we\n        // pick)\x2C but pick the half that matches the pixel's x parity so that\n        // games packing distinct values still get a sensible fill.\n        const fillHi16 = (this.rspState.fillColor >>> 16) & 0xFFFF;\n        const fillLo16 =  this.rspState.fillColor        & 0xFFFF;\n\n        const yStart = Math.max(0\x2C Math.floor(y1 / 4));\n        const yEnd   = Math.min(239\x2C Math.floor(y2 / 4));\n        const xStart = Math.max(0\x2C Math.floor(x1 / 4));\n        const xEnd   = Math.min(w - 1\x2C Math.floor(x2 / 4));\n\n        // GL renderer tap (Task #40): color fills become scissored clears; fills\n        // aimed at the depth image become depth clears.\n        if (this.glr) { this.glr.fillRect(this\x2C xStart\x2C yStart\x2C xEnd\x2C yEnd); return; }\n\n        for (let y = yStart; y <= yEnd; y++) {\n            for (let x = xStart; x <= xEnd; x++) {\n                const p = (addr + (y * w + x) * bpp) & 0x7FFFFF;\n                if (sz === 3) rd.setUint32(p\x2C this.rspState.fillColor >>> 0\x2C false);\n                else if (sz === 2) rd.setUint16(p\x2C (x & 1) ? fillLo16 : fillHi16\x2C false);\n                else rd.setUint8(p\x2C this.rspState.fillColor & 0xFF);\n            }\n        }\n    }\n\n    // Composite a 1-/2-cycle G_FILLRECT (fade/letterbox overlay) through the\n    // combiner+blender\x2C exactly like a non-textured texrect. Used for OoT's\n    // full-screen fade-in/out and the logo-screen black borders (Task #57).\n    _compositeOverlayFillRect(hi\x2C lo) {\n        const rs = this.rspState;\n        const addr = rs.colorImage;\n        if (!addr && addr !== 0) return;\n        const w = rs.colorImageWidth | 0;\n        if (w <= 0) return;\n        const cSz = rs.colorImageSize;\n        const x2 = (hi >>> 12) & 0xFFF\x2C y2 = hi & 0xFFF\x2C x1 = (lo >>> 12) & 0xFFF\x2C y1 = lo & 0xFFF;\n        const xStart = Math.max(0\x2C Math.floor(x1 / 4));\n        const xEnd   = Math.min(w - 1\x2C Math.floor(x2 / 4));\n        const yStart = Math.max(0\x2C Math.floor(y1 / 4));\n        const yEnd   = Math.min(239\x2C Math.floor(y2 / 4));\n        if (xStart > xEnd || yStart > yEnd) return;\n\n        // Flat-shade\x2C no-texture inputs (a fill rect has no shade gradient or\n        // texcoords). The combiner's fade colour comes from PRIM/ENV.\n        const shade = { r: 255\x2C g: 255\x2C b: 255\x2C a: 255 };\n        const tex = { r: 255\x2C g: 255\x2C b: 255\x2C a: 255 };\n        const combineActive = !!(rs.combine.hi || rs.combine.lo);\n        const blActive = this.blenderActive();\n        if (combineActive) this._setupCombine();\n        if (blActive) this._setupBlend();\n\n        const base = combineActive ? this.combineColor(shade\x2C tex) : shade;\n        // Fully transparent overlay with no FB-reading blender \u2192 nothing to do\n        // (avoids stamping a 0-alpha colour over the scene).\n        if (!blActive && base.a < 1) return;\n\n        const rd = new DataView(this.mmu.memory.rdram);\n        const bpp = (cSz === 3) ? 4 : 2;\n        for (let y = yStart; y <= yEnd; y++) {\n            for (let x = xStart; x <= xEnd; x++) {\n                const p = (addr + (y * w + x) * bpp) & 0x7FFFFF;\n                let color = base;\n                if (blActive) color = this.blendPixel(base\x2C this.readMemColor(rd\x2C p\x2C cSz)\x2C undefined);\n                else if (color.a < 1) continue;\n                if (cSz === 2) {\n                    rd.setUint16(p\x2C\n                        (((color.r >> 3) & 0x1F) << 11) |\n                        (((color.g >> 3) & 0x1F) << 6)  |\n                        (((color.b >> 3) & 0x1F) << 1)  |\n                        (color.a > 127 ? 1 : 0)\x2C false);\n                } else if (cSz === 3) {\n                    rd.setUint32(p\x2C ((color.r << 24) | (color.g << 16) | (color.b << 8) | (color.a & 0xFF)) >>> 0\x2C false);\n                }\n            }\n        }\n    }\n\n    drawTriangle(v1\x2C v2\x2C v3) {\n        this.drawStats.triangles++;\n        if (this.rspState.useTexture) this.drawStats.texturedTriangles++;\n        else this.drawStats.untexturedTriangles++;\n        if (this.rspState.textureEnabled) this.drawStats.textureEnabledTriangles++;\n        else this.drawStats.textureDisabledTriangles++;\n        this.recordVideoWrite('tri');\n        this.drawStats.minX = Math.min(this.drawStats.minX\x2C v1.x\x2C v2.x\x2C v3.x);\n        this.drawStats.minY = Math.min(this.drawStats.minY\x2C v1.y\x2C v2.y\x2C v3.y);\n        this.drawStats.maxX = Math.max(this.drawStats.maxX\x2C v1.x\x2C v2.x\x2C v3.x);\n        this.drawStats.maxY = Math.max(this.drawStats.maxY\x2C v1.y\x2C v2.y\x2C v3.y);\n        const addr = this.rspState.colorImage;\n        if (!addr) return;\n\n        // Early reject \u2014 all three vertices on the same side of the screen.\n        // Sutherland\u2013Hodgman correctly handles this case but it costs allocation\n        // and a fan pass per triangle\x2C which adds up over a million-triangle\n        // boot intro. The simple AABB check below catches most off-screen\n        // geometry without running the full pipeline.\n        const sw = (this.rspState.colorImageWidth | 0) || 320;\n        const sh = 240;\n        if ((v1.x < 0 && v2.x < 0 && v3.x < 0) ||\n            (v1.x >= sw && v2.x >= sw && v3.x >= sw) ||\n            (v1.y < 0 && v2.y < 0 && v3.y < 0) ||\n            (v1.y >= sh && v2.y >= sh && v3.y >= sh)) {\n            this.drawStats.offscreenTriangles = (this.drawStats.offscreenTriangles | 0) + 1;\n            return;\n        }\n\n        // Stage 1: clip in clip space against the near plane. libultra row-vector\n        // projection produces |W| ~ |z_eye|\x2C with W's sign depending on the game's\n        // matrix conventions. The triangle is "in front of the eye" if all\n        // vertices share the same nonzero W sign and |W| is bounded below. We\n        // clip against the plane W = nearW (in whichever sign hemisphere the\n        // first vertex sits) so straddling triangles are trimmed before the\n        // perspective divide blows them up to huge screen extents.\n        const clippedClip = this.clipTriangleNearPlane(v1\x2C v2\x2C v3);\n        if (clippedClip.length < 3) return;\n\n        // Stage 2: perspective-divide each clipped vertex back to screen space.\n        // The vertices that didn't move through clipping reuse their cached\n        // screen coords; new vertices generated by the clipper compute fresh ones.\n        const screenPoly = clippedClip.map(v => {\n            if (v._needsProject) {\n                const p = this.projectClipToScreen(v.cx\x2C v.cy\x2C v.cz\x2C v.cw);\n                return {\n                    x: p.sx\x2C y: p.sy\x2C z: p.sz\x2C w: v.cw\x2C\n                    cx: v.cx\x2C cy: v.cy\x2C cz: v.cz\x2C cw: v.cw\x2C\n                    r: v.r\x2C g: v.g\x2C b: v.b\x2C a: v.a\x2C\n                    s: v.s\x2C t: v.t\x2C\n                    _needsProject: false\n                };\n            }\n            return v;\n        });\n\n        // Stage 2.5: backface culling based on geometryMode. Both microcodes\n        // expose CULL_FRONT and CULL_BACK flags but at different bit positions:\n        //   Fast3D:  CULL_FRONT=0x1000\x2C CULL_BACK=0x2000\n        //   F3DEX2:  CULL_FRONT=0x0200\x2C CULL_BACK=0x0400\n        // SM64 sets G_CULL_BACK on most opaque geometry\x2C which currently\n        // double-shades back-facing triangles over front-facing ones.\n        const gm = this.rspState.geometryMode >>> 0;\n        const cullFrontBit = this.rspState.isF3DEX2 ? 0x00000200 : 0x00001000;\n        const cullBackBit  = this.rspState.isF3DEX2 ? 0x00000400 : 0x00002000;\n        const cullFront = (gm & cullFrontBit) !== 0;\n        const cullBack  = (gm & cullBackBit)  !== 0;\n        // Screen-space signed area in Y-down coordinates.\n        // Front-facing (CCW in Y-up world) maps to NEGATIVE area after Y-flip in projection.\n        // Back-facing  (CW  in Y-up world) maps to POSITIVE area.\n        // So CULL_BACK removes area > 0\x2C CULL_FRONT removes area < 0.\n        if (cullFront || cullBack) {\n            const a = screenPoly[0]\x2C b = screenPoly[1]\x2C c = screenPoly[2];\n            const area = (b.x - a.x) * (c.y - a.y) - (c.x - a.x) * (b.y - a.y);\n            if (cullBack && cullFront) { this.drawStats.culledTriangles = (this.drawStats.culledTriangles|0)+1; return; }\n            if (cullBack  && area > 0) { this.drawStats.culledTriangles = (this.drawStats.culledTriangles|0)+1; return; }\n            if (cullFront && area < 0) { this.drawStats.culledTriangles = (this.drawStats.culledTriangles|0)+1; return; }\n        }\n\n        // GL renderer tap (Task #40): hand the clipped\x2C culled screen-space fan\n        // to the WebGL backend and skip software rasterization entirely.\n        if (this.glr) { this.glr.triFan(screenPoly\x2C this); return; }\n\n        // Stage 3: clip against the screen-edge rectangle and rasterize as a fan.\n        for (let i = 1; i < screenPoly.length - 1; i++) {\n            const tri = this.clipTriangleToViewport(\n                screenPoly[0]\x2C screenPoly[i]\x2C screenPoly[i + 1]\x2C\n                this.rspState.colorImageWidth\x2C 240\n            );\n            if (tri.length < 3) continue;\n            for (let j = 1; j < tri.length - 1; j++) {\n                this.rasterizeTriangle(tri[0]\x2C tri[j]\x2C tri[j + 1]\x2C addr);\n            }\n        }\n    }\n\n    // Clip a triangle against the near plane in clip space using Sutherland\u2013Hodgman.\n    // We pick the sign hemisphere from the first vertex with |cw| above a small\n    // epsilon (libultra-row-vector projection can yield either sign). The plane\n    // we clip against is `signed_w >= nearW`\x2C where signed_w = cw if the\n    // hemisphere is positive\x2C or -cw if negative. This keeps tiny/near-eye W\n    // values from being perspective-divided into the next county.\n    clipTriangleNearPlane(v1\x2C v2\x2C v3) {\n        const poly = [v1\x2C v2\x2C v3];\n        // --- Modern microcode path (F3DEX 1.x / F3DEX2): true frustum near-plane\n        //     clip in homogeneous clip space (Task #52). ---\n        // The legacy SM64/F3D path below clips against an ad-hoc W=1 plane\x2C which\n        // is NOT the actual frustum near plane. For games that submit large ground\n        // polygons whose near edge passes through (or behind) the camera \u2014 e.g.\n        // MK64's racetrack/grass \u2014 the W=1 clip generates intersection vertices on\n        // the W=1 plane with large CX\x2C which perspective-divide to coordinates like\n        // (-84354\x2C-14086). The viewport clip then clamps that giant off-screen\n        // triangle into a thin on-screen sliver = the green wedge across the centre.\n        //\n        // libultra row-vector projection: NDC_z = cz/cw \u2208 [-1\x2C1]\x2C so the near plane\n        // is cz/cw = -1\x2C i.e. the homogeneous plane (cz + cw) = 0; "in front of near"\n        // is (cz + cw) >= 0. We also clip against the W > 0 plane so behind-camera\n        // geometry (cw <= 0) is rejected. Vertices interpolated on the true near\n        // plane satisfy cz + cw = 0 (NDC_z = -1) and therefore project to bounded\x2C\n        // on-frustum screen coordinates. SM64 is F3D (triIndexScale 10) and uses the\n        // untouched legacy path \u2192 byte-identical baseline.\n        if (this.rspState.isF3DEX2 || this.rspState.triIndexScale === 2) {\n            const cz = (v) => (v.cz !== undefined ? v.cz : v.z);\n            const cw = (v) => (v.cw !== undefined ? v.cw : v.w);\n            // W-hemisphere normalization (Task #55). OoT's F3DZEX perspective\n            // matrix yields NEGATIVE clip-space W for in-front geometry \u2014 the\n            // opposite hemisphere from MK64/SM64 (positive W). NDC = c/w is\n            // invariant under negating (cx\x2Ccy\x2Ccz\x2Ccw)\x2C so a triangle that sits\n            // wholly in the negative hemisphere is flipped into the positive one\n            // before the standard near-plane clip below. Without this\x2C the\n            // `cw > EPS` plane rejected EVERY OoT scene triangle (0 px rendered)\n            // even though the projection math already handled negative W. MK64\n            // (positive W) is untouched: the all-negative test is never true.\n            let work = poly;\n            if (cw(v1) < 0 && cw(v2) < 0 && cw(v3) < 0) {\n                work = poly.map((v) => this._negateClipVertex(v));\n            }\n            // Plane 1: W > epsilon (reject behind-camera / degenerate-near geometry).\n            const EPS = 1e-4;\n            let poly1 = this.clipClipPlane(work\x2C (v) => cw(v) - EPS);\n            if (poly1.length <