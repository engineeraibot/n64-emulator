eLength;\n        let pos = (flags & 0x1) ? 0 : ((stateAddr + 1 < lim) ? rd.getUint16(stateAddr\x2C false) : 0);\n        for (let s = 0; s < outSamples; s++) {\n            const ip = pos >>> 16;\n            const frac = (pos & 0xFFFF) / 65536;\n            const a = this.adGetS16(dmemi + ip * 2);\n            const b = this.adGetS16(dmemi + (ip + 1) * 2);\n            this.adSetS16(dmemo + s * 2\x2C (a + (b - a) * frac) | 0);\n            pos = (pos + pitch) >>> 0;\n        }\n        if (stateAddr + 1 < lim) rd.setUint16(stateAddr\x2C pos & 0xFFFF\x2C false);\n    }\n\n    aMixer(w0\x2C w1) {\n        const gain = (w0 & 0xFFFF) << 16 >> 16; // s16\n        const dmemin = (w1 >>> 16) & 0xFFFF;\n        const dmemout = w1 & 0xFFFF;\n        const n = this.alistCount >> 1; // s16 sample count\n        for (let i = 0; i < n; i++) {\n            const inS = this.adGetS16(dmemin + i * 2);\n            const outS = this.adGetS16(dmemout + i * 2);\n            this.adSetS16(dmemout + i * 2\x2C outS + ((inS * gain) >> 15));\n        }\n    }\n\n    // s16 clamp.\n    clampS16(v) { v |= 0; return v > 32767 ? 32767 : (v < -32768 ? -32768 : v); }\n\n    // dst = clamp_s16(dst + ((src*gain)>>15)).  src\x2Cgain are s16.\n    sampleMix(off\x2C src\x2C gain) {\n        this.adSetS16(off\x2C this.adGetS16(off) + ((src * gain) >> 15));\n    }\n\n    // One envelope ramp step (mupen ramp_step): advance value by step\x2C clamp at target\x2C\n    // return (int16_t)(value >> 16). value/step/target are 64-bit-range JS Numbers\x2C so\n    // the >>16 uses Math.floor (arithmetic shift) rather than the 32-bit JS >> operator.\n    rampStep(val\x2C step\x2C target\x2C ch) {\n        val[ch] += step[ch];\n        const reached = (step[ch] <= 0) ? (val[ch] <= target[ch]) : (val[ch] >= target[ch]);\n        if (reached) { val[ch] = target[ch]; step[ch] = 0; }\n        return (Math.floor(val[ch] / 65536) << 16) >> 16; // (int16_t)(value >> 16)\n    }\n\n    // A_ENVMIXER (exp variant \u2014 S