eturn [1\x2C0\x2C0\x2C0\x2C 0\x2C1\x2C0\x2C0\x2C 0\x2C0\x2C1\x2C0\x2C 0\x2C0\x2C0\x2C1]; }\n\n    multiplyMatrices(a\x2C b) {\n        // Row-major 4x4 multiply: res = a * b where a\x2C b\x2C res use a[row*4+col].\n        // (libultra's readMatrix produces a row-major flat array.)\n        const res = new Array(16).fill(0);\n        for (let r = 0; r < 4; r++) {\n            for (let c = 0; c < 4; c++) {\n                res[r * 4 + c] =\n                    a[r * 4 + 0] * b[0 * 4 + c] +\n                    a[r * 4 + 1] * b[1 * 4 + c] +\n                    a[r * 4 + 2] * b[2 * 4 + c] +\n                    a[r * 4 + 3] * b[3 * 4 + c];\n            }\n        }\n        return res;\n    }\n\n    readMatrix(addr) {\n        // libultra Mtx layout: two 32-byte halves (integer\x2C then fractional).\n        // Each half stores 16 16-bit values laid out as `s32 m[8][2]`\x2C i.e.\n        // bytes 0-3 = (M[0][0]_int\x2C M[0][1]_int)\x2C bytes 4-7 = (M[0][2]_int\x2C\n        // M[0][3]_int)\x2C bytes 8-11 = (M[1][0]_int\x2C M[1][1]_int)\x2C etc.\n        // Returned flat array is row-major: m[row*4 + col] = M[row][col].\n        const m = new Array(16);\n        for (let row = 0; row < 4; row++) {\n            for (let pair = 0; pair < 2; pair++) {\n                const idx = row * 2 + pair;\n                const hiWord = this.mmu.read32(addr + idx * 4) >>> 0;\n                const loWord = this.mmu.read32(addr + 32 + idx * 4) >>> 0;\n                const fixed0 = (((hiWord & 0xFFFF0000) >>> 0) | (loWord >>> 16)) | 0;\n                const fixed1 = ((((hiWord & 0xFFFF) << 16) >>> 0) | (loWord & 0xFFFF)) | 0;\n                m[row * 4 + pair * 2] = fixed0 / 65536.0;\n                m[row * 4 + pair * 2 + 1] = fixed1 / 65536.0;\n            }\n        }\n        return m;\n    }\n\n    resolveAddress(addr) {\n        const seg = (addr >>> 24) & 0xF;\n        const base = this.rspState.segments[seg];\n        const res = (base + (addr & 0x00FFFFFF)) >>> 0;\n        