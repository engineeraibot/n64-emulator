script-source,80,/sessions/admiring-clever-gauss/mnt/n64-emulator-main/tmp_state.js,// Reusable save/restore of full machine state for fast post-title debugging.\nconst fs=require('fs');\nfunction saveState(file\x2C ram\x2C mmu\x2C cpu\x2C rcp){\n  const meta={\n    cpu:{\n      gpr:Array.from(cpu.gpr)\x2C gprHi:Array.from(cpu.gprHi)\x2C\n      cp0:Array.from(cpu.cp0Registers)\x2C\n      fpr:Buffer.from(new Uint8Array(cpu.fprBuffer)).toString('base64')\x2C\n      fcr0:cpu.fcr0\x2C fcr31:cpu.fcr31\x2C pc:cpu.pc|0\x2C\n      hi:cpu.hi|0\x2C lo:cpu.lo|0\x2C hiH:cpu.hiH|0\x2C loH:cpu.loH|0\x2C\n      compareArmed:cpu._compareArmed\x2C lastFiredCompare:cpu._lastFiredCompare\x2C\n      instructionCount:cpu.instructionCount\x2C\n      isHleBootDone:cpu.isHleBootDone\x2C isRunning:cpu.isRunning\x2C\n      branchTaken:cpu.branchTaken\x2C branchTarget:cpu.branchTarget|0\x2C\n      tlb:cpu.tlbEntries.map(e=>e?{pageMask:e.pageMask\x2CentryHi:e.entryHi\x2CentryLo0:e.entryLo0\x2CentryLo1:e.entryLo1}:null)\x2C\n    }\x2C\n    mmu:{\n      vi:Array.from(mmu.viRegisters)\x2C mi:Array.from(mmu.miRegisters)\x2C\n      pi:Array.from(mmu.piRegisters)\x2C si:Array.from(mmu.siRegisters)\x2C\n      sp:Array.from(mmu.spRegisters)\x2C dpc:Array.from(mmu.dpcRegisters)\x2C\n      ai:Array.from(mmu.aiRegisters)\x2C ri:Array.from(mmu.riRegisters)\x2C\n      pifRam:Buffer.from(mmu.pifRam).toString('base64')\x2C\n      eeprom:Buffer.from(mmu.eeprom).toString('base64')\x2C\n      spDmem:Buffer.from(mmu.spDmem).toString('base64')\x2C\n      spImem:Buffer.from(mmu.spImem).toString('base64')\x2C\n      piBusyUntil:mmu.piBusyUntil\x2C siBusyUntil:mmu.siBusyUntil\x2C\n      aiBusyUntil:mmu.aiBusyUntil\x2C aiQueuedDuration:mmu.aiQueuedDuration\x2C\n      viNextInterrupt:mmu.viNextInterrupt\x2C siDmaDirection:mmu.siDmaDirection\x2C\n      siDramAddr:mmu.siDramAddr\x2C buttons:mmu.buttons\x2C stickX:mmu.stickX\x2C stickY:mmu.stickY\x2C\n    }\x2C\n    rcp:{ f3dTaskCount:rcp.f3dTaskCount|0\x2C rspTaskCount:rcp.rspTaskCount|0 }\x2C\n  };\n  fs.writeFileSync(file+'.rdram'\x2C Buffer.from(new Uint8Array(ram.rdram)));\n  fs.writeFileSync(file+'.json'\x2C JSON.stringify(meta));\n}\nfunction loadState(file\x2C ram\x2C mmu\x2C cpu\x2C rcp){\n  const rd=fs.readFileSync(file+'.rdram');\n  new Uint8Array(ram.rdram).set(new Uint8Array(rd.buffer\x2Crd.byteOffset\x2Crd.byteLength));\n  const m=JSON.parse(fs.readFileSync(file+'.json'\x2C'utf8'));\n  const c=m.cpu;\n  cpu.gpr.set(c.gpr); cpu.gprHi.set(c.gprHi); cpu.cp0Registers.set(c.cp0);\n  new Uint8Array(cpu.fprBuffer).set(Buffer.from(c.fpr\x2C'base64'));\n  cpu.fcr0=c.fcr0; cpu.fcr31=c.fcr31; cpu.pc=c.pc|0;\n  cpu.hi=c.hi|0; cpu.lo=c.lo|0; cpu.hiH=c.hiH|0; cpu.loH=c.loH|0;\n  cpu._compareArmed=c.compareArmed; cpu._lastFiredCompare=c.lastFiredCompare;\n  cpu.instructionCount=c.instructionCount;\n  cpu.isHleBootDone=c.isHleBootDone; cpu.isRunning=c.isRunning;\n  cpu.branchTaken=c.branchTaken; cpu.branchTarget=c.branchTarget|0;\n  cpu.tlbEntries=c.tlb.map(e=>e?{pageMask:e.pageMask\x2CentryHi:e.entryHi\x2CentryLo0:e.entryLo0\x2CentryLo1:e.entryLo1}:null);\n  cpu.fetchPage=-1; cpu.fetchView=null;\n  const mm=m.mmu;\n  mmu.viRegisters.set(mm.vi); mmu.miRegisters.set(mm.mi); mmu.piRegisters.set(mm.pi);\n  mmu.siRegisters.set(mm.si); mmu.spRegisters.set(mm.sp); mmu.dpcRegisters.set(mm.dpc);\n  mmu.aiRegisters.set(mm.ai); mmu.riRegisters.set(mm.ri);\n  mmu.pifRam.set(Buffer.from(mm.pifRam\x2C'base64'));\n  mmu.eeprom.set(Buffer.from(mm.eeprom\x2C'base64'));\n  mmu.spDmem.set(Buffer.from(mm.spDmem\x2C'base64'));\n  mmu.spImem.set(Buffer.from(mm.spImem\x2C'base64'));\n  mmu.piBusyUntil=mm.piBusyUntil; mmu.siBusyUntil=mm.siBusyUntil;\n  mmu.aiBusyUntil=mm.aiBusyUntil; mmu.aiQueuedDuration=mm.aiQueuedDuration;\n  mmu.viNextInterrupt=mm.viNextInterrupt; mmu.siDmaDirection=mm.siDmaDirection;\n  mmu.siDramAddr=mm.siDramAddr; mmu.buttons=mm.buttons; mmu.stickX=mm.stickX; mmu.stickY=mm.stickY;\n  return m;\n}\nmodule.exports={saveState\x2CloadState};\n
