            this.rspState.vertices[dest + i] = {\n                x: proj.sx\x2C y: proj.sy\x2C z: proj.sz\x2C w: tw\x2C\n                cx: tx\x2C cy: ty\x2C cz: tz\x2C cw: tw\x2C\n                r\x2C g\x2C b\x2C a\x2C\n                s: (this.mmu.read16(v + 8) << 16) >> 16\x2C t: (this.mmu.read16(v + 10) << 16) >> 16\n            };\n        }\n    }\n\n    // Compute lit shade for a vertex normal. Returns {r\x2C g\x2C b} in [0\x2C 255].\n    // Uses configured lights (from G_MOVEMEM index G_MV_L0..7 + ambient slot)\n    // if present\x2C otherwise falls back to a default ambient + key light so\n    // SM64's Mario isn't pitch-black before the game finishes setting up lights.\n    computeLitShade(nx\x2C ny\x2C nz) {\n        const lights = this.rspState.lights;\n        const numLights = this.rspState.numLights | 0;\n        let ambR\x2C ambG\x2C ambB;\n        let dirLights;\n        if (lights && numLights > 0 && lights[numLights]) {\n            const amb = lights[numLights];\n            ambR = amb.r; ambG = amb.g; ambB = amb.b;\n            dirLights = lights.slice(0\x2C numLights);\n        } else {\n            // Default: warm ambient + one front-up key light. Matches what the\n            // SM64 boot intro looks like before the game's own light setup\n            // takes over.\n            ambR = 64; ambG = 64; ambB = 64;\n            dirLights = [{ r: 200\x2C g: 200\x2C b: 200\x2C dx: 0.4\x2C dy: 0.7\x2C dz: 0.6 }];\n        }\n        let R = ambR\x2C G = ambG\x2C B = ambB;\n        for (const L of dirLights) {\n            const dot = nx * L.dx + ny * L.dy + nz * L.dz;\n            const k = dot > 0 ? dot : 0;\n            R += L.r * k;\n            G += L.g * k;\n            B += L.b * k;\n        }\n        return {\n            r: R > 255 ? 255 : (R < 0 ? 0 : R | 0)\x2C\n            g: G > 255 ? 255 : (G < 0 ? 0 : G | 0)\x2C\n            b: B > 255 ? 255 : (B < 0 ? 0 : B | 0)\n        };\n    }\n\n    // Apply perspective divide + viewport map